#!/usr/bin/env python3
import sys, time

# Simple typewriter effect
def say(text, delay=0.03):
    for c in text:
        sys.stdout.write(c)
        sys.stdout.flush()
        time.sleep(delay)
    print()

# Player stats and inventory
player = {"name":"Player", "hp":10, "inventory":[]}

# Adventure scenes
scenes = {
    "start": {
        "desc": "You awaken in a mysterious cosmic chamber. A glowing terminal hums nearby. Paths lie before you: left (l), right (r).",
        "choices": {"l":"library", "r":"lab"}
    },
    "library": {
        "desc": "You enter an ancient library filled with holographic tomes. A floating book offers knowledge or power (k/p).",
        "choices": {"k":"knowledge_room", "p":"power_room"}
    },
    "lab": {
        "desc": "A futuristic lab hums with Beep Boop modules. You can interact with AI (a) or explore the back door (b).",
        "choices": {"a":"ai_room", "b":"secret_room"}
    },
    "knowledge_room": {
        "desc": "You gain wisdom from the tomes. HP +2",
        "choices": {}, "effect": lambda: player.update({"hp":player["hp"]+2})
    },
    "power_room": {
        "desc": "You are imbued with strange energy. Inventory +1 mysterious artifact",
        "choices": {}, "effect": lambda: player["inventory"].append("mysterious artifact")
    },
    "ai_room": {
        "desc": "Beep Boop greets you. It offers a riddle: solve (s) or ignore (i).",
        "choices": {"s":"riddle_room", "i":"hallway"}
    },
    "secret_room": {
        "desc": "You find a hidden stash of cosmic credits. Inventory +3 credits",
        "choices": {}, "effect": lambda: player["inventory"].extend(["credit"]*3)
